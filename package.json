{
  "name": "@unityinflow/spec-linter",
  "version": "0.0.0",
  "description": "Lint CLAUDE.md and AI spec files — catches missing sections, secrets, and context bloat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "spec-linter": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --check src/ tests/",
    "format:fix": "prettier --write src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "lint",
    "spec",
    "ai",
    "claude-code",
    "claude-md"
  ],
  "author": "Jiri Hermann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UnityInFlow/spec-linter.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
